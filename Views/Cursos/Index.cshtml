@model IEnumerable<Practica2_Teoria.Models.Curso>

@{
    ViewData["Title"] = "Catálogo de cursos";
    var request = ViewContext.HttpContext.Request;
    string? nombre = request.Query["nombre"];
    string? creditosMin = request.Query["creditosMin"];
    string? creditosMax = request.Query["creditosMax"];
    string? horarioInicio = request.Query["horarioInicio"];
    string? horarioFin = request.Query["horarioFin"];
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start mb-4">
    <div>
        <h1 class="mb-1">Catálogo de cursos</h1>
        <p class="text-muted">Explora todos los cursos disponibles y encuentra el que mejor se adapte a tus necesidades.</p>
    </div>
    <span class="badge bg-primary text-white py-2 px-3 align-self-start">@Model.Count() cursos encontrados</span>
</div>

<div class="card card-surface mb-4 p-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-lg-3 col-md-4">
            <label class="form-label" for="nombre">Nombre</label>
            <input class="form-control" type="text" name="nombre" id="nombre" value="@nombre" placeholder="Buscar curso" />
        </div>
        <div class="col-lg-2 col-md-4">
            <label class="form-label" for="creditosMin">Créditos mínimos</label>
            <input class="form-control" type="number" min="0" name="creditosMin" id="creditosMin" value="@creditosMin" />
        </div>
        <div class="col-lg-2 col-md-4">
            <label class="form-label" for="creditosMax">Créditos máximos</label>
            <input class="form-control" type="number" min="0" name="creditosMax" id="creditosMax" value="@creditosMax" />
        </div>
        <div class="col-lg-2 col-md-4">
            <label class="form-label" for="horarioInicio">Horario inicio</label>
            <input class="form-control" type="time" name="horarioInicio" id="horarioInicio" value="@horarioInicio" />
        </div>
        <div class="col-lg-2 col-md-4">
            <label class="form-label" for="horarioFin">Horario fin</label>
            <input class="form-control" type="time" name="horarioFin" id="horarioFin" value="@horarioFin" />
        </div>
        <div class="col-lg-1 col-md-4 d-grid">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </form>
</div>

<div class="row g-4">
    @foreach (var curso in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="course-card card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge bg-primary">@curso.Codigo</span>
                        <span class="badge bg-@((curso.Activo ? "success" : "secondary"))">@(curso.Activo ? "Activo" : "Inactivo")</span>
                    </div>
                    <h5 class="card-title">@curso.Nombre</h5>
                    <p class="card-text text-muted mb-4">Horario: @curso.HorarioInicio.ToString("HH:mm") - @curso.HorarioFin.ToString("HH:mm")</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-1"><strong>Créditos:</strong> @curso.Creditos</p>
                            <p class="mb-0"><strong>Cupo:</strong> @curso.CupoMaximo</p>
                        </div>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@curso.Id">Ver detalle</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
